<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.fast.succour.mapper.AdoptMapper">

    <resultMap type="Adopt" id="AdoptResult">
        <result property="adoptId"    column="adopt_id"    />
        <result property="animalId"    column="animal_id"    />
        <result property="name"    column="name"    />
        <result property="phone"    column="phone"    />
        <result property="email"    column="email"    />
        <result property="address"    column="address"    />
        <result property="occupation"    column="occupation"    />
        <result property="reason"    column="reason"    />
        <result property="petExperience"    column="pet_experience"    />
        <result property="status"    column="status"    />
        <result property="description"    column="description"    />
        <result property="userId"    column="user_id"    />
        <result property="createTime"    column="create_time"    />
        <result property="animalName"    column="animalName"    />
        <result property="userName"    column="user_name"    />
        <result property="stationForUserId" column="stationForUserId" />
    </resultMap>

    <select id="selectAdoptList" parameterType="Adopt" resultMap="AdoptResult">
        select ad.adopt_id, ad.animal_id, ad.name, ad.phone, ad.email, ad.address, ad.occupation,
               ad.reason, ad.pet_experience, ad.status, ad.description, ad.user_id, ad.create_time,
               an.name as animalName,
               u.user_name,
               s.user_id as stationForUserId
        from adopt ad
        left join animal an on ad.animal_id = an.animal_id
        left join sys_user u on ad.user_id = u.user_id
        left join station s on an.station_id = s.station_id
        <where>
            <if test="animalId != null  and animalId != ''"> and ad.animal_id = #{animalId}</if>
            <if test="status != null  and status != ''"> and ad.status = #{status}</if>
            <if test="userId != null "> and ad.user_id = #{userId}</if>
            <if test="animalName != null  and animalName != ''">
                and an.name like concat('%', #{animalName}, '%')
            </if>
            <if test="userName != null  and userName != ''">
                and u.user_name like concat('%', #{userName}, '%')
            </if>
            <if test="stationForUserId != null "> and s.user_id = #{stationForUserId}</if>
        </where>
        order by ad.create_time desc
    </select>

    <select id="selectAdoptByAdoptId" parameterType="String" resultMap="AdoptResult">
        select adopt_id, animal_id, name, phone, email, address, occupation, reason, pet_experience, status, description, user_id, create_time from adopt
        where adopt_id = #{adoptId}
    </select>

    <insert id="insertAdopt" parameterType="Adopt">
        insert into adopt
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="adoptId != null and adoptId != ''">adopt_id,</if>
            <if test="animalId != null and animalId != ''">animal_id,</if>
            <if test="name != null and name != ''">name,</if>
            <if test="phone != null and phone != ''">phone,</if>
            <if test="email != null and email != ''">email,</if>
            <if test="address != null and address != ''">address,</if>
            <if test="occupation != null and occupation != ''">occupation,</if>
            <if test="reason != null and reason != ''">reason,</if>
            <if test="petExperience != null and petExperience != ''">pet_experience,</if>
            <if test="status != null and status != ''">status,</if>
            <if test="description != null and description != ''">description,</if>
            <if test="userId != null">user_id,</if>
            <if test="createTime != null">create_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="adoptId != null and adoptId != ''">#{adoptId},</if>
            <if test="animalId != null and animalId != ''">#{animalId},</if>
            <if test="name != null and name != ''">#{name},</if>
            <if test="phone != null and phone != ''">#{phone},</if>
            <if test="email != null and email != ''">#{email},</if>
            <if test="address != null and address != ''">#{address},</if>
            <if test="occupation != null and occupation != ''">#{occupation},</if>
            <if test="reason != null and reason != ''">#{reason},</if>
            <if test="petExperience != null and petExperience != ''">#{petExperience},</if>
            <if test="status != null and status != ''">#{status},</if>
            <if test="description != null and description != ''">#{description},</if>
            <if test="userId != null">#{userId},</if>
            <if test="createTime != null">#{createTime},</if>
        </trim>
    </insert>

    <update id="updateAdopt" parameterType="Adopt">
        update adopt
        <trim prefix="SET" suffixOverrides=",">
            <if test="animalId != null and animalId != ''">animal_id = #{animalId},</if>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="phone != null and phone != ''">phone = #{phone},</if>
            <if test="email != null and email != ''">email = #{email},</if>
            <if test="address != null and address != ''">address = #{address},</if>
            <if test="occupation != null and occupation != ''">occupation = #{occupation},</if>
            <if test="reason != null and reason != ''">reason = #{reason},</if>
            <if test="petExperience != null and petExperience != ''">pet_experience = #{petExperience},</if>
            <if test="status != null and status != ''">status = #{status},</if>
            <if test="description != null and description != ''">description = #{description},</if>
            <if test="userId != null">user_id = #{userId},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
        </trim>
        where adopt_id = #{adoptId}
    </update>

    <delete id="deleteAdoptByAdoptIds" parameterType="String">
        delete from adopt where adopt_id in
        <foreach item="adoptId" collection="array" open="(" separator="," close=")">
            #{adoptId}
        </foreach>
    </delete>
</mapper>
